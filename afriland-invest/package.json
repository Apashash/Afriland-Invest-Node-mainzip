{
  "name": "afriland-invest",
  "version": "1.0.0",
  "description": "AFRILAND INVEST - Plateforme d'investissement",
  "main": "dist/index.cjs",
  "scripts": {
    "start": "node server/index.js",
    "start:prod": "NODE_ENV=production node dist/index.cjs",
    "dev": "nodemon server/index.js",
    "build:client": "cd client && npm install && npx vite build --outDir ../dist/public --emptyOutDir",
    "build:server": "npx esbuild server/index.js --bundle --platform=node --format=cjs --outfile=dist/index.cjs --packages=external",
    "build": "npm run build:client && npm run build:server",
    "install-all": "npm install && cd client && npm install"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.108.1",
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "express-rate-limit": "^7.1.5",
    "helmet": "^7.1.0",
    "jsonwebtoken": "^9.0.2",
    "morgan": "^1.10.0",
    "multer": "^2.2.0",
    "pg": "^8.22.0",
    "uuid": "^11.1.1",
    "ws": "^8.21.0"
  },
  "devDependencies": {
    "esbuild": "^0.28.1",
    "nodemon": "^3.0.2"
  },
  "overrides": {
    "qs": "^6.15.3",
    "js-yaml": "^4.3.0",
    "markdown-it": "^14.2.0",
    "linkify-it": "^5.0.1",
    "@babel/core": "^7.29.6"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
